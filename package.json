{
  "name": "lib-frodo",
  "version": "1.0.0",
  "type": "module",
  "description": "lib-frodo is a multi-platform Node.js library that provides JavaScript bindings for various interactions within ForgeRock your products. lib-frodo enables anyone to build client software such as CLI's, GUI's or other tooling.",
  "main": "src/index.js",
  "scripts": {
    "doc": "typedoc ./src/bindings/*.js",
    "generate-typescript-support": "tsc -p tsconfig.json",
    "test_api": "cd ./test/api/ && node --experimental-vm-modules ../../node_modules/jest/bin/jest.js",
    "test_e2e": "cd ./test/e2e/ && node --experimental-vm-modules ../../node_modules/jest/bin/jest.js",
    "test_unit": "cd ./test/units/ && node --experimental-vm-modules ../../node_modules/jest/bin/jest.js"
  },
  "contributors": [
    {
      "name": "Sandeep Chaturvedi",
      "email": "sandeep.chaturvedi@forgerock.com"
    },
    {
      "name": "Adam Crockett",
      "email": "adam.crockett@forgerock.com"
    },
    {
      "name": "Ali Falahi",
      "email": "ali.falahi@forgerock.com"
    },
    {
      "name": "Volker Scheuber",
      "email": "volker.scheuber@forgerock.com"
    }
  ],
  "license": "MIT",
  "dependencies": {
    "atob": "^2.1.2",
    "btoa": "^1.2.1",
    "axios": "^0.25.0",
    "axios-retry": "^3.2.4",
    "fs-extra": "^10.0.0",
    "properties-reader": "^2.2.0",
    "qs": "^6.10.3",
    "uuid": "^8.3.2"
  },
  "devDependencies": {
    "@types/uuid": "8.3.4",
    "dotenv": "16.0.1",
    "eslint": "^8.10.0",
    "eslint-config-airbnb": "^19.0.4",
    "eslint-config-prettier": "^8.4.0",
    "eslint-plugin-import": "^2.25.4",
    "eslint-plugin-jsx-a11y": "^6.5.1",
    "eslint-plugin-prettier": "^4.0.0",
    "eslint-plugin-react": "^7.29.2",
    "eslint-plugin-react-hooks": "^4.3.0",
    "jest": "27.5.1",
    "typedoc": "0.23.6",
    "typedoc-plugin-markdown": "3.13.3",
    "typescript": "4.7.3"
  }
}
